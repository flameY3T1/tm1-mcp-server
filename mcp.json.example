{
  "_comment": "Copy to .mcp.json (project-local) or merge into ~/.claude/settings.json. Credentials live in .env, not here. autoApprove lists READ-ONLY tools only — destructive tools (delete/clear/unload/cancel/execute/remove/invalidate) MUST stay out of this list and require manual approval. TM1_SSL_REJECT_UNAUTHORIZED=false disables TLS certificate verification — use only for self-signed dev certs, never in production.",
  "mcpServers": {
    "tm1": {
      "command": "node",
      "args": ["/absolute/path/to/tm1-mcp-server/dist/index.js"],
      "autoApprove": [
        "tm1_analyze_callgraph",
        "tm1_analyze_chore_graph",
        "tm1_analyze_object_usage",
        "tm1_check_cube_rule",
        "tm1_check_process_code",
        "tm1_check_writable_coords",
        "tm1_compile_process",
        "tm1_diff_process_with_file",
        "tm1_execute_mdx",
        "tm1_export_process_to_pro",
        "tm1_get_all_cube_rules",
        "tm1_get_all_processes_code",
        "tm1_get_cell_value",
        "tm1_get_client",
        "tm1_get_cube_rules",
        "tm1_get_cube_stats",
        "tm1_get_element_attribute_values",
        "tm1_get_error_log_content",
        "tm1_get_file_content",
        "tm1_get_hierarchy",
        "tm1_get_message_log",
        "tm1_get_process_code",
        "tm1_get_process_datasource",
        "tm1_get_process_parameters",
        "tm1_get_process_variables",
        "tm1_get_server_info",
        "tm1_get_server_state",
        "tm1_get_subset",
        "tm1_get_transaction_log",
        "tm1_get_view",
        "tm1_list_chores",
        "tm1_list_clients",
        "tm1_list_cubes",
        "tm1_list_dimensions",
        "tm1_list_element_attributes",
        "tm1_list_error_logs",
        "tm1_list_files",
        "tm1_list_groups",
        "tm1_list_processes",
        "tm1_list_sessions",
        "tm1_list_subsets",
        "tm1_list_threads",
        "tm1_list_views",
        "tm1_search_code",
        "tm1_validate_process_refs"
      ]
    }
  }
}
