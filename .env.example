TM1_BASE_URL=https://localhost:8010
TM1_USER=admin
TM1_PASSWORD=your-password
# --- CAM (Cognos Access Manager) login (optional) ---
# Native TM1 auth is the default (no namespace). For CAM, set TM1_NAMESPACE to
# your CAM namespace — the client then sends
#   Authorization: CAMNamespace base64(user:password:namespace)
# (TM1_USER/TM1_PASSWORD still required). On PA Cloud the namespace is usually LDAP
# and you must use a non-interactive service account from the welcome kit.
# TM1_NAMESPACE=LDAP
# Alternatively, supply a pre-obtained CAM passport (e.g. from an SSO gateway).
# Takes precedence over namespace/Basic; TM1_USER/TM1_PASSWORD are not needed.
#   Authorization: CAMPassport <token>
# TM1_CAM_PASSPORT=
# NOTE: base64 is encoding, not encryption — always use HTTPS (TM1_BASE_URL=https://).
# Windows SSO via SSPI/negotiate is not supported; obtain a passport out-of-band.
# Verify TLS certificates. Default: true (secure). Uncomment and set false ONLY
# for self-signed dev certs — never in production.
# TM1_SSL_REJECT_UNAUTHORIZED=false
TM1_KEEP_ALIVE_INTERVAL=60000
TM1_REQUEST_TIMEOUT=600000
TM1_LOG_LEVEL=info
# Write logs to a file instead of stderr (path; default: stderr only).
# TM1_LOG_FILE=
# Tool exposure mode: "readonly" (DEFAULT) or "readwrite".
# readonly registers only read tools — write/destructive tools (delete, upsert,
# import, save-data, run-process) are not exposed at all. This is the safe
# default so an unconfigured server cannot mutate or delete TM1 objects.
# Set readwrite ONLY when you intend to let the agent change the model, and
# never point a readwrite server at production without reviewing the write path.
# TM1_MODE=readwrite
# TM1 server version. "11.x" disables v12-only features (e.g. DataSource.usesUnicode).
TM1_VERSION=11.8
# Host-file access for the .pro round-trip tools (diff/validate/export/import/install).
# DEFAULT-OFF: when unset, filePath/writeToFile/directory parameters are rejected and
# those tools only accept inline 'content'. Set to an allowed directory to enable host
# file read/write; supplied paths must resolve INSIDE this root (no ".." traversal).
# Keeps arbitrary host file read (e.g. /proc/self/environ, ~/.ssh) off the tool surface.
# TM1_LOCAL_FILE_ROOT=/srv/tm1-pro-bundles

# --- MCP transport (optional) ---
# Default transport is stdio (local Claude Code / Desktop). Switch to Streamable HTTP for remote/multi-client.
# TM1_MCP_TRANSPORT=http
# TM1_MCP_HTTP_HOST=127.0.0.1          # bind loopback only; 0.0.0.0 exposes credentials to the LAN
# TM1_MCP_HTTP_PORT=3000
# TM1_MCP_HTTP_ALLOWED_ORIGINS=        # comma-separated extra Origins allowed past DNS-rebinding protection
# TM1_MCP_HTTP_TOKEN=                  # require "Authorization: Bearer <token>" on /mcp; unset = no transport auth
