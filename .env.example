TM1_BASE_URL=https://localhost:8010
TM1_USER=admin
TM1_PASSWORD=your-password
# Verify TLS certificates. Set false ONLY for self-signed dev certs — never in production.
TM1_SSL_REJECT_UNAUTHORIZED=false
TM1_KEEP_ALIVE_INTERVAL=60000
TM1_REQUEST_TIMEOUT=600000
TM1_LOG_LEVEL=info
# Write logs to a file instead of stderr (path; default: stderr only).
# TM1_LOG_FILE=
# Tool exposure mode: "readwrite" (default) or "readonly" (hides all writing/destructive tools).
# Use "readonly" when pointing at a production instance.
# TM1_MODE=readwrite
# TM1 server version. "11.x" disables v12-only features (e.g. DataSource.usesUnicode).
TM1_VERSION=11.8

# --- MCP transport (optional) ---
# Default transport is stdio (local Claude Code / Desktop). Switch to Streamable HTTP for remote/multi-client.
# TM1_MCP_TRANSPORT=http
# TM1_MCP_HTTP_HOST=127.0.0.1          # bind loopback only; 0.0.0.0 exposes credentials to the LAN
# TM1_MCP_HTTP_PORT=3000
# TM1_MCP_HTTP_ALLOWED_ORIGINS=        # comma-separated extra Origins allowed past DNS-rebinding protection
# TM1_MCP_HTTP_TOKEN=                  # require "Authorization: Bearer <token>" on /mcp; unset = no transport auth
