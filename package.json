{
  "name": "tm1-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for IBM Planning Analytics / TM1 — full model lifecycle via REST API",
  "repository": {
    "type": "git",
    "url": "https://github.com/flameY3T1/tm1-mcp-server.git"
  },
  "author": "flameY3T1",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:property": "vitest run tests/property",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "lint:no-flat-api": "node scripts/check-no-flat-tm1-methods.mjs",
    "lint:annotations": "node scripts/check-annotation-coverage.mjs",
    "verify": "npm run typecheck && npm run lint:no-flat-api && npm run lint:annotations && npm test",
    "tools:list": "node scripts/gen-tool-list.mjs",
    "tools:update-readme": "node scripts/gen-tool-list.mjs --write-readme"
  },
  "keywords": [
    "mcp",
    "tm1",
    "planning-analytics",
    "ibm"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "dotenv": "^17.4.1",
    "pino": "^10.3.1",
    "undici": "^7.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.5",
    "fast-check": "^4.6.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
