{
  "name": "tm1-mcp-server",
  "version": "2.1.0",
  "description": "MCP server for IBM Planning Analytics / TM1 \u2014 full model lifecycle via REST API",
  "repository": {
    "type": "git",
    "url": "https://github.com/flameY3T1/tm1-mcp-server.git"
  },
  "author": "flameY3T1",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tm1-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run verify",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:property": "vitest run tests/property",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && eslint .",
    "lint:no-flat-api": "node scripts/check-no-flat-tm1-methods.mjs",
    "lint:annotations": "node scripts/check-annotation-coverage.mjs",
    "verify": "npm run typecheck && npm run lint:no-flat-api && npm run lint:annotations && npm run lint:eslint && npm test",
    "tools:list": "node scripts/gen-tool-list.mjs",
    "tools:update-readme": "node scripts/gen-tool-list.mjs --write-readme",
    "lint:eslint": "eslint ."
  },
  "keywords": [
    "mcp",
    "tm1",
    "planning-analytics",
    "ibm"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "dotenv": "^17.4.1",
    "pino": "^10.3.1",
    "safe-regex": "^2.1.1",
    "undici": "^7.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/safe-regex": "^1.1.6",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "fast-check": "^4.8.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.2"
  }
}
